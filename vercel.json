{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/stellen", "dest": "/stellen.html" },
    { "src": "/betriebe", "dest": "/betriebe.html" },
    { "src": "/stellen.html", "dest": "/stellen.html" },
    { "src": "/betriebe.html", "dest": "/betriebe.html" }
  ]
}
